# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# For Vercel Edge/Client-side deployments, if accessing Gemini directly from the client:
VITE_GEMINI_API_KEY=""

# ============================================================================
# SUPABASE CONFIGURATION & INITIALIZATION
# ============================================================================

# Supabase Project URL:
# Get from: https://app.supabase.com > Project Settings > API > Project URL
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Supabase Anonymous Key (Public):
# Get from: https://app.supabase.com > Project Settings > API > anon key
VITE_SUPABASE_ANON_KEY="your_anon_key_here"

# Supabase Service Role Key (Private - Keep Secret!)
# Get from: https://app.supabase.com > Project Settings > API > service_role key
# This is used ONLY on the server side for migration and admin operations
# NEVER expose this in client-side code or to the browser
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key_here"

# Database URL with embedded credentials
# Format: postgres://user:password@host:port/database
SUPABASE_DB_URL="postgres://postgres:your_database_password@your-project.supabase.co:5432/postgres"

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Application mode
VITE_ENV="production"

# API Base URL (if applicable)
VITE_API_URL="http://localhost:3000"

# Enable offline support
VITE_OFFLINE_ENABLED="true"

# Enable debug logging
VITE_DEBUG="false"

# ============================================================================
# MIGRATION CONFIGURATION (for migrate-firebase-to-supabase.js)
# ============================================================================

# Path to Firebase service account JSON
# Download from: https://console.firebase.google.com > Project Settings > Service Accounts
FIREBASE_CONFIG_PATH="./firebase-applet-config.json"

# Batch size for migration (number of records per batch)
# Increase for faster migration, decrease if experiencing memory issues
# Recommended: 100-500
BATCH_SIZE="200"

# Timeout settings (in milliseconds)
FIREBASE_TIMEOUT="15000"
SUPABASE_TIMEOUT="15000"

# ============================================================================
# FEATURE FLAGS
# ============================================================================

VITE_INVENTORY_BATCHES_ENABLED="true"
VITE_COMPLIANCE_MODE="true"
VITE_MULTI_CURRENCY="true"
VITE_OFFLINE_MODE="true"
VITE_REAL_TIME_SYNC="true"

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

VITE_LOG_QUERIES="false"
VITE_LOG_ERRORS="true"

# ============================================================================
# INTEGRATION SERVICES (ZIMRA, PAYNOW, NOTIFICATIONS)
# ============================================================================

# ZIMRA FDMS Configuration 
VITE_ZIMRA_API_URL="https://testfdms.zimra.co.zw/api"

# Feature Flags
VITE_ENABLE_AI_FEATURES="true"
VITE_MAINTENANCE_MODE="false"

# Zimbabwe Paynow Payment Gateway Integration keys
# Log in to your Paynow merchant portal to retrieve these live configuration keys
PAYNOW_INTEGRATION_ID=""
PAYNOW_INTEGRATION_KEY=""

# Multi-channel Notification Integrations
# Target phone for real-time WhatsApp alerts. Default Country Code (263 for Zimbabwe)
NOTIFICATION_WHATSAPP_PHONE="263784553570"
# Option A: Callmebot API (Direct Personal WhatsApp alert key)
CALLMEBOT_API_KEY=""
# Option B: Twilio API Secrets for general WhatsApp notification API
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM="+14155238886"

# Alert Forwarder SMTP Email Credentials
NOTIFICATION_RECEIVER_EMAIL="tapsforex@gmail.com"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# ============================================================================
# OPTIONAL: FIREBASE CONFIGURATION (for rollback scenarios)
# ============================================================================
# NOTE: Populate these variables in your Project Settings to link Firebase fallback if needed.
# If these variables are not set, the app will fall back automatically to the firebase-applet-config.json.
VITE_FIREBASE_API_KEY="AIzaSyYourApiKeyHere"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_DATABASE_URL="https://your-project-default-rtdb.firebaseio.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="(default)"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="1:your-sender-id:web:your-app-id"
VITE_FIREBASE_MEASUREMENT_ID="G-your-measurement-id"
