{
  "entities": {
    "Business": {
      "title": "Business",
      "description": "Represents an enterprise organization using Tareza ERP",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "tax_number": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "currency": { "type": "string" },
        "subscription_plan": { "type": "string" },
        "subscription_status": { "type": "string" },
        "max_users": { "type": "number" },
        "max_branches": { "type": "number" },
        "smtp_host": { "type": "string" },
        "smtp_port": { "type": "number" },
        "smtp_user": { "type": "string" },
        "smtp_pass": { "type": "string" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Branch": {
      "title": "Branch",
      "description": "A physical retail store or warehouse belonging to a business",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "business_id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "type": { "type": "string" },
        "is_active": { "type": "boolean" },
        "created_at": { "type": "string" }
      },
      "required": ["id", "business_id", "name"]
    },
    "Profile": {
      "title": "Profile",
      "description": "User profile with personal identity details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "first_name": { "type": "string" },
        "last_name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "required": ["id", "email"]
    },
    "BusinessUser": {
      "title": "BusinessUser",
      "description": "Relational link mapping a user's role and branch inside a business",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "business_id": { "type": "string" },
        "user_id": { "type": "string" },
        "branch_id": { "type": "string" },
        "role_id": { "type": "string" },
        "is_active": { "type": "boolean" },
        "created_at": { "type": "string" }
      },
      "required": ["id", "business_id", "user_id"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories configured within a business",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "business_id": { "type": "string" },
        "name": { "type": "string" },
        "parent_id": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "required": ["id", "business_id", "name"]
    },
    "Product": {
      "title": "Product",
      "description": "A single retail catalog item/product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "business_id": { "type": "string" },
        "category_id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "sku": { "type": "string" },
        "barcode": { "type": "string" },
        "retail_price": { "type": "number" },
        "wholesale_price": { "type": "number" },
        "cost_price": { "type": "number" },
        "tax_class": { "type": "string" },
        "is_active": { "type": "boolean" },
        "created_at": { "type": "string" }
      },
      "required": ["id", "business_id", "name", "retail_price"]
    },
    "Inventory": {
      "title": "Inventory",
      "description": "Tracks stock levels of products at specific branches",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "business_id": { "type": "string" },
        "branch_id": { "type": "string" },
        "product_id": { "type": "string" },
        "quantity": { "type": "number" },
        "reorder_level": { "type": "number" },
        "created_at": { "type": "string" }
      },
      "required": ["id", "business_id", "branch_id", "product_id", "quantity"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A customer transaction / sale record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "business_id": { "type": "string" },
        "branch_id": { "type": "string" },
        "user_id": { "type": "string" },
        "customer_id": { "type": "string" },
        "receiptNumber": { "type": "string" },
        "subtotal": { "type": "number" },
        "vat_total": { "type": "number" },
        "discount_total": { "type": "number" },
        "total": { "type": "number" },
        "payment_method": { "type": "string" },
        "status": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "required": ["id", "business_id", "branch_id", "total"]
    },
    "CashDrawerLog": {
      "title": "CashDrawerLog",
      "description": "Audit trails for cash flow adjustments and till additions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "business_id": { "type": "string" },
        "branch_id": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string" },
        "transaction_type": { "type": "string" },
        "notes": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "required": ["id", "business_id", "branch_id", "amount", "type"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "Represents user raised technical or billing support inquiries",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "user_email": { "type": "string" },
        "business_id": { "type": "string" },
        "business_name": { "type": "string" },
        "subject": { "type": "string" },
        "category": { "type": "string" },
        "priority": { "type": "string" },
        "status": { "type": "string" },
        "description": { "type": "string" },
        "response": { "type": "string" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "required": ["id", "user_id", "subject", "description"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Represents a vendor/supplier in the business directory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "business_id": { "type": "string" },
        "name": { "type": "string" },
        "contact_person": { "type": "string" },
        "contact_name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "payment_terms": { "type": "string" },
        "balance": { "type": "number" },
        "status": { "type": "string" },
        "tax_number": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "required": ["id", "business_id", "name"]
    },
    "PurchaseOrder": {
      "title": "PurchaseOrder",
      "description": "Represents a procurement purchase order placed with a supplier",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "business_id": { "type": "string" },
        "supplier_id": { "type": "string" },
        "status": { "type": "string" },
        "total_amount": { "type": "number" },
        "po_number": { "type": "string" },
        "order_date": { "type": "string" },
        "expected_delivery_date": { "type": "string" },
        "items": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "required": ["id", "business_id", "supplier_id"]
    },
    "Currency": {
      "title": "Currency",
      "description": "Custom transaction and billing currency for multi-currency compliance",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "business_id": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "symbol": { "type": "string" },
        "exchange_rate": { "type": "number" },
        "is_base": { "type": "boolean" },
        "is_active": { "type": "boolean" },
        "created_at": { "type": "string" }
      },
      "required": ["id", "business_id", "code", "exchange_rate"]
    },
    "ExchangeRateHistory": {
      "title": "ExchangeRateHistory",
      "description": "Audit and timeline log of historical exchange rate updates",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "currency_id": { "type": "string" },
        "rate": { "type": "number" },
        "effective_date": { "type": "string" }
      },
      "required": ["id", "currency_id", "rate", "effective_date"]
    },
    "InventoryBatch": {
      "title": "InventoryBatch",
      "description": "Tracks batch numbers and expiration dates for compliance with health regulations",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "business_id": { "type": "string" },
        "branch_id": { "type": "string" },
        "product_id": { "type": "string" },
        "batch_number": { "type": "string" },
        "expiry_date": { "type": "string" },
        "quantity": { "type": "number" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "required": ["id", "business_id", "branch_id", "product_id", "batch_number", "expiry_date", "quantity"]
    }
  },
  "firestore": {
    "/businesses/{businessId}": {
      "schema": "Business",
      "description": "Businesses registered in Tareza ERP"
    },
    "/branches/{branchId}": {
      "schema": "Branch",
      "description": "Retail branches"
    },
    "/profiles/{userId}": {
      "schema": "Profile",
      "description": "User login profiles"
    },
    "/business_users/{bUserId}": {
      "schema": "BusinessUser",
      "description": "Roles and branches assignment logs"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Master products database"
    },
    "/inventory/{inventoryId}": {
      "schema": "Inventory",
      "description": "Current stock levels per branch"
    },
    "/inventory_batches/{batchId}": {
      "schema": "InventoryBatch",
      "description": "Stock levels tracked per specific batch and expiration date"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sale transactions"
    },
    "/cash_drawer_logs/{logId}": {
      "schema": "CashDrawerLog",
      "description": "Cash movement logs"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Vendor directory profile"
    },
    "/purchase_orders/{poId}": {
      "schema": "PurchaseOrder",
      "description": "Procurement purchase orders"
    },
    "/support_tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Log of client help desk tickets"
    },
    "/currencies/{currencyId}": {
      "schema": "Currency",
      "description": "Corporate or multi-currency definitions"
    },
    "/exchange_rate_history/{historyId}": {
      "schema": "ExchangeRateHistory",
      "description": "Historic ledger exchange rates references"
    }
  }
}
