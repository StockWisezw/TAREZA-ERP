{
  "entities": {
    "Business": {
      "title": "Business",
      "description": "A tenant/business in the ERP",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name"]
    },
    "Profile": {
      "title": "Profile",
      "description": "User profile",
      "type": "object",
      "properties": {
        "first_name": { "type": "string" },
        "last_name": { "type": "string" }
      }
    },
    "Branch": {
      "title": "Branch",
      "description": "Business branch",
      "type": "object",
      "properties": {
        "business_id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" }
      }
    },
    "Role": {
      "title": "Role",
      "type": "object",
      "properties": {
        "business_id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "properties": {
        "business_id": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "Subscription": {
      "title": "Subscription",
      "type": "object",
      "properties": {
        "business_id": { "type": "string" },
        "plan_name": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "BusinessUser": {
      "title": "Business User",
      "description": "Link between user, business and branch",
      "type": "object",
      "properties": {
        "business_id": { "type": "string" },
        "user_id": { "type": "string" }
      }
    },
    "Product": {
       "title": "Product",
       "type": "object",
       "properties": {
          "business_id": { "type": "string" },
          "name": { "type": "string" },
          "barcode": { "type": "string" },
          "sku": { "type": "string" }
       }
    },
    "Customer": {
       "title": "Customer",
       "type": "object",
       "properties": {
          "business_id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" }
       }
    },
    "Supplier": {
       "title": "Supplier",
       "type": "object",
       "properties": {
          "business_id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" }
       }
    },
    "Inventory": {
       "title": "Inventory",
       "type": "object",
       "properties": {
          "business_id": { "type": "string" },
          "branch_id": { "type": "string" },
          "product_id": { "type": "string" },
          "quantity": { "type": "number" }
       }
    },
    "Sale": {
       "title": "Sale",
       "type": "object",
       "properties": {
          "business_id": { "type": "string" },
          "branch_id": { "type": "string" },
          "total_amount": { "type": "number" }
       }
    },
    "ChatMessage": {
       "title": "Chat Message",
       "type": "object",
       "properties": {
          "channel_id": { "type": "string" },
          "user_id": { "type": "string" },
          "content": { "type": "string" }
       }
    }
  },
  "firestore": {
    "/businesses/{businessId}": {
      "schema": "Business",
      "description": "Businesses"
    },
    "/profiles/{userId}": {
      "schema": "Profile",
      "description": "User profiles"
    },
    "/branches/{branchId}": {
      "schema": "Branch",
      "description": "Branches of a business"
    },
    "/roles/{roleId}": {
      "schema": "Role",
      "description": "Roles associated with businesses"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Categories for products"
    },
    "/subscriptions/{subId}": {
      "schema": "Subscription",
      "description": "Business subscriptions"
    },
    "/business_users/{businessUserId}": {
        "schema": "BusinessUser",
        "description": "Junction table for users and businesses"
    },
    "/products/{productId}": {
        "schema": "Product",
        "description": "Inventory products"
    },
    "/customers/{customerId}": {
        "schema": "Customer",
        "description": "Customers"
    },
    "/suppliers/{supplierId}": {
        "schema": "Supplier",
        "description": "Suppliers"
    },
    "/inventory/{inventoryId}": {
        "schema": "Inventory",
        "description": "Inventory levels"
    },
    "/sales/{saleId}": {
        "schema": "Sale",
        "description": "Sales records"
    }
  }
}
