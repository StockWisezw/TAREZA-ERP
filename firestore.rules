rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Validation
    function isValidBusiness(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200;
    }
    
    function isValidProfile(data) {
      return data.keys().hasAll(['first_name', 'last_name', 'email']) &&
             data.first_name is string && data.first_name.size() <= 100 &&
             data.last_name is string && data.last_name.size() <= 100;
    }
    
    // Businesses
    match /businesses/{businessId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidBusiness(incoming());
      allow update: if isSignedIn() && isValidBusiness(incoming());
      allow delete: if false;
    }

    // Profiles
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidProfile(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidProfile(incoming());
      allow delete: if false;
    }

    // Branches
    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().keys().hasAll(['business_id', 'name']);
      allow update: if isSignedIn();
    }

    // Business Users
    match /business_users/{buId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().keys().hasAll(['business_id', 'user_id']);
    }

    // Roles
    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().keys().hasAll(['business_id', 'name']);
    }

    // Categories
    match /categories/{catId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().keys().hasAll(['business_id', 'name']);
    }
    
    // Subscriptions
    match /subscriptions/{subId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().keys().hasAll(['business_id', 'plan_name']);
    }

    // Products
    match /products/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /customers/{id} {
      allow read, write: if isSignedIn();
    }

    match /suppliers/{id} {
      allow read, write: if isSignedIn();
    }

    match /inventory/{id} {
      allow read, write: if isSignedIn();
    }

    match /sales/{id} {
      allow read, write: if isSignedIn();
    }
    match /tax_rates/{id} { allow read, write: if isSignedIn(); }
    match /inventory_transfers/{id} { allow read, write: if isSignedIn(); }
    match /stock_movements/{id} { allow read, write: if isSignedIn(); }
    match /stocktakes_advanced/{id} { allow read, write: if isSignedIn(); }
    match /purchase_orders/{id} { allow read, write: if isSignedIn(); }
    match /chat_channels/{id} {
      allow read, write: if isSignedIn();
    }
    match /chat_messages/{id} {
      allow read, write: if isSignedIn();
    }
  }
}
