rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helper validation functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserBusinessId() {
      return get(/databases/$(database)/documents/business_users/$(request.auth.uid)).data.business_id;
    }
    
    function belongsToUserBusiness(bizId) {
      return isSignedIn() && bizId != null && bizId != "" && 
             exists(/databases/$(database)/documents/business_users/$(request.auth.uid)) && 
             getUserBusinessId() == bizId;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function businessIdUnchanged() {
      return existing().business_id == incoming().business_id;
    }

    function isSystemDeveloper() {
      return isSignedIn() && 
        request.auth.token.email != null && (
          request.auth.token.email.lower().endsWith("@tarezaerp.co.zw") ||
          request.auth.token.email.lower() == "admin@tarezaerp.co.zw" ||
          request.auth.token.email.lower() == "developer@tarezaerp.co.zw" ||
          request.auth.token.email.lower() == "dev@tarezaerp.co.zw" ||
          request.auth.token.email.lower() == "tapsforex@gmail.com"
        );
    }

    // 1. Profiles (Owner and Developer)
    match /profiles/{profileId} {
      allow read, write: if isSystemDeveloper() || (isSignedIn() && request.auth.uid == profileId);
    }
    
    // 2. Business Users linkage (Tenancy gatekeeper)
    match /business_users/{userId} {
      allow read: if isSystemDeveloper() || (isSignedIn() && (
        request.auth.uid == userId ||
        (resource != null && resource.data.user_id == request.auth.uid) ||
        belongsToUserBusiness(existing().business_id)
      ));
      allow write: if isSystemDeveloper() || (isSignedIn() && (
        request.auth.uid == userId || 
        (incoming() != null && incoming().user_id == request.auth.uid)
      ) && (
        resource == null ||
        belongsToUserBusiness(existing().business_id)
      ));
    }
    
    // 3. Businesses Profile
    match /businesses/{businessId} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(businessId);
      allow write: if isSystemDeveloper() || 
                   belongsToUserBusiness(businessId) || 
                   (request.resource.data.system_admin_key == "paynow_secure_bypass_3892");
    }
    
    // 4. Primary Business Scoped Tables (Strict business_id tenancy checks with Developer bypass)
    
    match /branches/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }
    
    match /roles/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }

    match /role_permissions/{id} {
      allow read, write: if isSystemDeveloper();
    }
    
    match /categories/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }
    
    match /products/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }
    
    match /inventory/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }
    
    match /customers/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }
    
    match /suppliers/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }
    
    match /sales/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }

    match /sale_items/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }
    
    match /expense_categories/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }
    
    match /cash_drawer_logs/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }
    
    match /tax_rates/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }
    
    match /purchase_orders/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }
    
    match /stocktakes_advanced/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }
    
    match /inventory_transfers/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }

    match /stock_movements/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }

    match /inventory_batches/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }
    
    match /subscriptions/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || 
                   (belongsToUserBusiness(incoming().business_id) && (resource == null || businessIdUnchanged())) ||
                   (request.resource.data.system_admin_key == "paynow_secure_bypass_3892");
    }
    
    match /accounts/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }
    
    match /journal_entries/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }

    match /journal_lines/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }
    
    match /register_sessions/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }
    
    // System audit logger (Trace compliance)
    match /audit_logs/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }
    
    match /support_tickets/{id} {
      allow read: if isSystemDeveloper() || (isSignedIn() && (
        request.auth.uid == existing().user_id ||
        belongsToUserBusiness(existing().business_id)
      ));
      allow write: if isSystemDeveloper() || (isSignedIn() && (
        request.auth.uid == incoming().user_id ||
        belongsToUserBusiness(incoming().business_id)
      ) && (resource == null || businessIdUnchanged()));
    }

    // 5. New custom collections for specialized user channels
    match /marketing_assets/{id} {
      allow read: if isSystemDeveloper() || (isSignedIn() && (
        resource == null || request.auth.uid == resource.data.userId
      ));
      allow write: if isSystemDeveloper() || (isSignedIn() && (
        request.resource.data.userId == request.auth.uid &&
        (resource == null || resource.data.userId == request.auth.uid)
      ));
    }

    match /private_messages/{id} {
      allow read: if isSystemDeveloper() || (isSignedIn() && (
        request.auth.uid == resource.data.sender_id ||
        request.auth.uid == resource.data.receiver_id
      ));
      allow write: if isSystemDeveloper() || (isSignedIn() && (
        request.auth.uid == request.resource.data.sender_id
      ));
    }

    match /trial_bookkeepings/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }

    match /currencies/{id} {
      allow read: if isSystemDeveloper() || belongsToUserBusiness(existing().business_id);
      allow write: if isSystemDeveloper() || (belongsToUserBusiness(incoming().business_id) && 
                    (resource == null || businessIdUnchanged()));
    }

    match /exchange_rate_history/{id} {
      allow read, write: if isSystemDeveloper() || isSignedIn();
    }

    match /test_connection/{id} {
      allow read: if true;
    }
  }
}
