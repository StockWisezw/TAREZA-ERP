rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helper validation functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserBusinessId() {
      return get(/databases/$(database)/documents/business_users/$(request.auth.uid)).data.business_id;
    }
    
    function belongsToUserBusiness(bizId) {
      return isSignedIn() && bizId != null && bizId != "" && getUserBusinessId() == bizId;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function businessIdUnchanged() {
      return existing().business_id == incoming().business_id;
    }

    // 1. Profiles (Owner only)
    match /profiles/{profileId} {
      allow read, write: if isSignedIn() && request.auth.uid == profileId;
    }
    
    // 2. Business Users linkage (Tenancy gatekeeper)
    match /business_users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        (resource != null && resource.data.user_id == request.auth.uid) ||
        belongsToUserBusiness(existing().business_id)
      );
      allow write: if isSignedIn() && (
        request.auth.uid == userId || 
        (incoming() != null && incoming().user_id == request.auth.uid)
      ) && (
        resource == null ||
        belongsToUserBusiness(existing().business_id)
      );
    }
    
    // 3. Businesses Profile
    match /businesses/{businessId} {
      allow read: if belongsToUserBusiness(businessId);
      allow write: if belongsToUserBusiness(businessId);
    }

    // 4. Primary Business Scoped Tables (Strict business_id tenancy checks)
    // All follow strict tenancy pattern:
    // 1. Each record MUST have business_id
    // 2. business_id cannot be modified
    // 3. User must own the business
    
    match /branches/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }
    
    match /roles/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }

    match /role_permissions/{id} {
      allow read, write: if false;
    }
    
    match /categories/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }
    
    match /products/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }
    
    match /inventory/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }
    
    match /customers/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }
    
    match /suppliers/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }
    
    match /sales/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }

    match /sale_items/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }
    
    match /expense_categories/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }
    
    match /cash_drawer_logs/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }
    
    match /tax_rates/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }
    
    match /purchase_orders/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }
    
    match /stocktakes_advanced/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }
    
    match /inventory_transfers/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }

    match /stock_movements/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }
    
    match /subscriptions/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }
    
    match /accounts/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }
    
    match /journal_entries/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }

    match /journal_lines/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }
    
    match /register_sessions/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }
    
    // System audit logger (Trace compliance)
    match /audit_logs/{id} {
      allow read: if belongsToUserBusiness(existing().business_id);
      allow write: if belongsToUserBusiness(incoming().business_id) && 
                   (resource == null || businessIdUnchanged());
    }
    
    match /support_tickets/{id} {
      allow read: if isSignedIn() && (
        request.auth.uid == existing().user_id ||
        belongsToUserBusiness(existing().business_id)
      );
      allow write: if isSignedIn() && (
        request.auth.uid == incoming().user_id ||
        belongsToUserBusiness(incoming().business_id)
      ) && (resource == null || businessIdUnchanged());
    }
  }
}
